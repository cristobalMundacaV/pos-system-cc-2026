# ============================================================
# BACKEND - VARIABLES DE ENTORNO
# Copiar este archivo a .env y completar los valores
# ============================================================

# Servidor
PORT=3001
NODE_ENV=development

# Base de Datos PostgreSQL
# TODO: En producción usar variables de entorno del servicio cloud
#       (AWS RDS, Google Cloud SQL, Azure Database for PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pos_db
DB_USER=postgres
DB_PASSWORD=postgres

# TODO: Habilitar SSL para conexiones a BD en producción
# DB_SSL=true

# JWT
# TODO: Cambiar por un secreto fuerte y almacenarlo en un servicio de secretos
#       (AWS Secrets Manager, Azure Key Vault, GCP Secret Manager)
JWT_SECRET=cambiar_este_secreto_en_produccion
JWT_EXPIRES_IN=8h

# CORS
# TODO: Reemplazar con la URL real del frontend en producción
# FRONTEND_URL=https://tu-dominio.com


# Almacenamiento de imágenes
# TODO: Configurar para usar almacenamiento en la nube
# AWS_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=

# Observabilidad (logging externo)
# LOG_LEVEL=info
# CLOUDWATCH_GROUP=
# DATADOG_API_KEY=
# SENTRY_DSN=

# Gestión de secretos
# AWS_SECRET_ARN=
# AZURE_KEY_VAULT_URL=
# GCP_SECRET_PROJECT=

# Pool de conexiones PostgreSQL
DB_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

LOG_LEVEL=info